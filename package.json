{
  "name": "sickofcodeblocks",
  "version": "0.3.0",
  "description": "Convert raw terminal/CLI output into clean plain text for pasting into email, Slack, and docs — no screenshots, no code blocks.",
  "keywords": [
    "ansi",
    "strip-ansi",
    "terminal",
    "tty",
    "clipboard",
    "plain-text",
    "cli",
    "slack",
    "email",
    "nerd-fonts",
    "redact",
    "sanitize"
  ],
  "license": "MIT",
  "author": "Sameer Zahir <sameerzahir97@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sickofcodeblocks": "dist/cli.js",
    "socb": "dist/cli.js",
    "socb-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "hooks",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^6.0.0"
  }
}
